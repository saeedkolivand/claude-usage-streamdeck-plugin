# dependencies (re-create with `npm install`)
node_modules/

# packaged output (re-create with `npx streamdeck pack ...`)
dist/
*.streamDeckPlugin

# preview / gallery generator temp bundles (re-create with `npm run preview` / `npm run gallery`)
scripts/.make-preview.mjs
scripts/.make-gallery.mjs

# logs / OS cruft
*.log
.DS_Store
Thumbs.db

# NOTE: com.saeedkolivand.claude-usage.sdPlugin/bin/plugin.js IS committed on purpose,
# so the plugin installs/packs without anyone needing to build first.
# If you'd rather keep a build-only repo, add this line:
# com.saeedkolivand.claude-usage.sdPlugin/bin/
